# Required — Neon Postgres connection string.
# Create a free project at https://neon.tech, then copy the pooled connection string.
DATABASE_URL="postgresql://user:password@ep-example-12345.us-east-2.aws.neon.tech/vitals?sslmode=require"

# Required — Google PageSpeed Insights API key (free).
# Get one at https://developers.google.com/speed/docs/insights/v5/get-started
# Free tier: 25,000 requests/day per project.
PAGESPEED_API_KEY=""

# Optional — WHOIS fallback if RDAP (used by default, no key needed) fails to
# resolve registrar/expiry data for a domain. WhoisXMLAPI free tier gives 500
# lookups/month: https://whois.whoisxmlapi.com
# Leave blank to skip this fallback — the DNS/WHOIS check still runs on RDAP alone.
WHOIS_API_KEY=""
